    <worksheet name='Revenue vs Profitability (Margin Leakage View)'>
      <layout-options>
        <caption>
          <formatted-text>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='11' lmargin='600' rmargin='600'>&quot;This scatter plot allows quick identification of high-revenue but loss-making sub-categories by dividing profit at zero, making margin leakage instantly visible.” </run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (SuperStore Sales DataSet)' name='federated.0851brr08q3wbf1h5glde00p5wbj' />
