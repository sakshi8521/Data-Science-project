    <worksheet name='Regional Profitability Risk Analysis'>
      <layout-options>
        <caption>
          <formatted-text>
            <run fontcolor='#000000' fontname='Times New Roman' fontsize='12' lmargin='600' rmargin='600'>“Implement region-specific discount controls, particularly in underperforming regions where aggressive pricing is not translating into sustainable profitability.While discounting negatively impacts profitability across all regions, the Central region shows a significantly steeper decline, indicating that aggressive discounting is particularly inefficient in this market.” </run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
