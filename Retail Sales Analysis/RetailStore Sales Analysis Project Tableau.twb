    <worksheet name='Profitability Gap'>
      <layout-options>
        <caption>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Times New Roman'>🟢 Observation:</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman'>“Sub-categories like Tables and Bookcases are generating significant sales volume but are operating at negative profit margins.” </run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Times New Roman'>🟡 Diagnosis:</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman'>“This indicates margin leakage likely due to high discounting, inefficient cost structure, or expensive fulfillment.” </run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Times New Roman'>🔴 Impact:</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman'>“These categories are inflating revenue but reducing overall profitability.” </run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Times New Roman'>🔵 Action:</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Times New Roman'>“We should implement discount controls, renegotiate supplier costs, or reconsider product strategy for these categories.”</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (SuperStore Sales DataSet)' name='federated.0851brr08q3wbf1h5glde00p5wbj' />
          </datasources>
          <datasource-dependencies datasource='federated.0851brr08q3wbf1h5glde00p5wbj'>
            <column caption='Profit Flag ' datatype='string' name='[Calculation_0654270929231873]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF SUM(Profit) &lt; 0 THEN &quot;Loss&quot;&#13;&#10;ELSE &quot;Profit&quot;&#13;&#10;END' />
            </column>
            <column datatype='real' name='[Profit]' role='measure' type='quantitative' />
            <column datatype='real' name='[Sales]' role='measure' type='quantitative' />
            <column datatype='string' name='[Sub-Category]' role='dimension' type='nominal' />
            <column-instance column='[Sub-Category]' derivation='None' name='[none:Sub-Category:nk]' pivot='key' type='nominal' />
