        <zone h='9977' id='16' name='Regional Profitability Risk Analysis' pane-specification-id='0' param='[federated.0851brr08q3wbf1h5glde00p5wbj].[none:Region:nk]' show-title='false' type-v2='color' w='6750' x='28688' y='59859' />
        <zone h='16197' id='30' name='Highest Loss Region' show-title='false' w='17875' x='33688' y='14085'>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='solid' />
            <format attr='border-width' value='1' />
            <_.fcp.DashboardRoundedCorners.true...format attr='corner-radius' value='8' />
          </zone-style>
        </zone>
        <zone h='24061' id='31' type-v2='text' w='27750' x='70750' y='58685'>
          <formatted-text>
            <run fontname='Times New Roman' fontsize='12'>• East region is the largest contributor to losses despite strong sales volume  </run>
            <run>Æ&#10;</run>
            <run fontname='Times New Roman' fontsize='12'>• Profitability declines sharply beyond ~20–30% discount levels  </run>
            <run>Æ&#10;</run>
            <run fontname='Times New Roman' fontsize='12'>• Central region shows unstable margins indicating pricing inefficiencies  </run>
            <run>Æ&#10;</run>
            <run fontname='Times New Roman' fontsize='12'>• West region is the only consistently profitable region with controlled discounting  </run>
          </formatted-text>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='solid' />
            <format attr='border-width' value='1' />
            <_.fcp.DashboardRoundedCorners.true...format attr='corner-radius' value='8' />
          </zone-style>
        </zone>
        <zone h='15141' id='32' type-v2='text' w='27688' x='70813' y='83451'>
          <formatted-text>
            <run fontname='Times New Roman' fontsize='12'>Losses are driven by high discounting rather than lack of sales. </run>
            <run>Æ&#10;</run>
            <run fontname='Times New Roman' fontsize='12'>Regions with aggressive discount strategies (East, Central) show both higher loss magnitude and higher margin volatility.</run>
          </formatted-text>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='solid' />
            <format attr='border-width' value='1' />
            <_.fcp.DashboardRoundedCorners.true...format attr='corner-radius' value='8' />
          </zone-style>
        </zone>
        <zone h='15728' id='33' type-v2='text' w='22000' x='52250' y='14437'>
          <formatted-text>
