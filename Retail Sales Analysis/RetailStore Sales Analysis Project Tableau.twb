    <worksheet name='Regionwise Loss'>
      <layout-options>
        <caption>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book' lmargin='600' rmargin='600'>“While the East region contributes the highest total losses in absolute terms, the Central region shows a steeper decline in profitability with increasing discounts, indicating a more inefficient pricing strategy. This suggests that losses in the East are volume-driven, whereas losses in Central are strategy-driven.” </run>
            <run lmargin='600' rmargin='600'>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book' lmargin='600' rmargin='600'>For East:</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Reduce </run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>volume of loss-making orders</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Æ </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Tighten discount approval </run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'> For Central:</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Fix </run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>pricing logic</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Æ </run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Set stricter discount thresholds</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sheet1 (SuperStore Sales DataSet)' name='federated.0851brr08q3wbf1h5glde00p5wbj' />
          </datasources>
          <datasource-dependencies datasource='federated.0851brr08q3wbf1h5glde00p5wbj'>
            <column caption='Total Loss' datatype='real' default-format='c&quot;$&quot;#,##0.00' name='[Calculation_0497865268953089]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [Loss Making Sub-Categories] THEN [Profit] END)' />
            </column>
            <column datatype='real' name='[Profit]' role='measure' type='quantitative' />
            <column datatype='string' name='[Region]' role='dimension' type='nominal' />
            <column datatype='string' name='[Sub-Category]' role='dimension' type='nominal' />
            <column-instance column='[Region]' derivation='None' name='[none:Region:nk]' pivot='key' type='nominal' />
            <column-instance column='[Sub-Category]' derivation='None' name='[none:Sub-Category:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_0497865268953089]' derivation='User' name='[usr:Calculation_0497865268953089:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0851brr08q3wbf1h5glde00p5wbj].[none:Sub-Category:nk]'>
            <groupfilter function='member' level='[none:Sub-Category:nk]' member='&quot;Tables&quot;' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate' />
