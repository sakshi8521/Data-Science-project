            <column-instance column='[Order ID]' derivation='None' name='[none:Order ID:nk]' pivot='key' type='nominal' />
            <column-instance column='[Region]' derivation='None' name='[none:Region:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1962419263934470]' derivation='Sum' name='[sum:Calculation_1962419263934470:qk]' pivot='key' type='quantitative' />
