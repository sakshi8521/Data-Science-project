      <aliases enabled='yes' />
      <column caption='Running Sales %' datatype='real' default-format='p0.00%' name='[Calculation_0121287455285248]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RUNNING_SUM(SUM([Sales])) / WINDOW_SUM(SUM([Sales]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Profit Margin %' datatype='real' default-format='p0.00%' name='[Calculation_0497865256755200]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit])/SUM([Sales])' />
      </column>
      <column caption='Total Loss' datatype='real' default-format='c&quot;$&quot;#,##0.00' name='[Calculation_0497865268953089]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Loss Making Sub-Categories] THEN [Profit] END)' />
      </column>
      <column caption='CalcLoss Indicator' datatype='string' name='[Calculation_0497865303465986]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0497865268953089] &lt; 0 THEN &quot;Loss&quot; ELSE &quot;Profit&quot; END' />
      </column>
      <column caption='Profit Category ' datatype='string' name='[Calculation_0497865384284163]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Profit]) &lt; 0 THEN &quot;Loss&quot; ELSE &quot;Profit&quot;&#13;&#10;END' />
      </column>
      <column caption='% of Revenue in Loss Categories' datatype='real' default-format='p0.00%' name='[Calculation_0654270922829824]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Loss Making Sub-Categories] THEN [Sales] END)&#13;&#10;/ SUM([Sales])' />
      </column>
      <column caption='Profit Flag ' datatype='string' name='[Calculation_0654270929231873]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM(Profit) &lt; 0 THEN &quot;Loss&quot;&#13;&#10;ELSE &quot;Profit&quot;&#13;&#10;END' />
      </column>
      <column caption='Loss Due to High Discounts' datatype='real' name='[Calculation_1962419039133696]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Discount] &gt; 0.2 THEN [Profit] END' />
      </column>
      <column caption='Profit Indicator' datatype='string' name='[Calculation_1962419065569281]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Profit]) &lt; 0 THEN &quot;Loss&quot;&#13;&#10;ELSE &quot;Profit&quot;&#13;&#10;END' />
      </column>
      <column caption='Worst Region ' datatype='string' name='[Calculation_1962419257499650]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Profit]) = WINDOW_MIN(SUM([Profit]))&#13;&#10;THEN &quot;Worst&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Profit Ratio' datatype='real' name='[Calculation_1962419263934470]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Profit] / [Sales]' />
      </column>
