    <dashboard enable-sort-zone-taborder='true' name='Price Drivers &amp; Diagnostics'>
      <style />
      <size maxheight='900' maxwidth='1200' minheight='700' minwidth='800' sizing-mode='range' />
      <zones>
        <zone h='52500' id='3' name='Price vs. Mileage' w='45667' x='1333' y='23750' />
        <zone h='49875' id='4' name='Price by Fuel Type' w='44917' x='52333' y='24250' />
        <zone h='13250' id='5' name='Price by Fuel Type' pane-specification-id='0' param='[federated.0cbq6ns1n6yph71f5a1z00bgag0u].[none:fuel:nk]' type-v2='color' w='11667' x='86333' y='20625' />
        <zone forceUpdate='true' h='10250' id='6' type-v2='text' w='52667' x='21000' y='6125'>
          <formatted-text>
            <run fontalignment='1' fontcolor='#000000' fontname='Times New Roman' fontsize='20'>What Drives Used Vehicle Prices?</run>
          </formatted-text>
          <zone-style>
            <format attr='border-color' value='#c0c0c0' />
            <format attr='border-style' value='solid' />
            <format attr='border-width' value='1' />
            <_.fcp.DashboardRoundedCorners.true...format attr='corner-radius' value='8' />
          </zone-style>
        </zone>
        <zone forceUpdate='true' h='17000' id='7' type-v2='text' w='38833' x='8250' y='79125'>
          <formatted-text>
            <run fontcolor='#000000' fontname='Times New Roman'>Performed a </run>
            <run bold='true' fontcolor='#000000' fontname='Times New Roman'>Bivariate Analysis</run>
            <run fontcolor='#000000' fontname='Times New Roman'> using a </run>
            <run bold='true' fontcolor='#000000' fontname='Times New Roman'>Linear Regression</run>
            <run fontcolor='#000000' fontname='Times New Roman'> model to quantify the negative correlation between odometer readings and vehicle valuation. To ensure statistical integrity,  applied </run>
            <run bold='true' fontcolor='#000000' fontname='Times New Roman'>Range Filters</run>
            <run fontcolor='#000000' fontname='Times New Roman'> to exclude extreme outliers, while adjusting the </run>
            <run bold='true' fontcolor='#000000' fontname='Times New Roman'>Coordinate Plane</run>
            <run fontcolor='#000000' fontname='Times New Roman'> to start at zero for logical consistency within the used vehicle market</run>
          </formatted-text>
          <zone-style>
            <format attr='border-color' value='#b4b4b4' />
            <format attr='border-style' value='solid' />
            <format attr='border-width' value='1' />
            <_.fcp.DashboardRoundedCorners.true...format attr='corner-radius' value='8' />
            <format attr='background-color' value='#f3faf9' />
          </zone-style>
        </zone>
        <zone forceUpdate='true' h='16667' id='8' type-v2='text' w='39500' x='56500' y='78991'>
          <formatted-text>
            <run fontcolor='#000000' fontname='Times New Roman'>Conducted a </run>
            <run bold='true' fontcolor='#000000' fontname='Times New Roman'>Categorical Distribution Analysis</run>
            <run fontcolor='#000000' fontname='Times New Roman'> using </run>
            <run bold='true' fontcolor='#000000' fontname='Times New Roman'>Box-and-Whisker Plots</run>
            <run fontcolor='#000000' fontname='Times New Roman'> to evaluate price variance across fuel types. By examining the </run>
            <run bold='true' fontcolor='#000000' fontname='Times New Roman'>Interquartile Range (IQR)</run>
            <run fontcolor='#000000' fontname='Times New Roman'> and </run>
            <run bold='true' fontcolor='#000000' fontname='Times New Roman'>Median</run>
            <run fontcolor='#000000' fontname='Times New Roman'> values, identified that while </run>
            <run bold='true' fontcolor='#000000' fontname='Times New Roman'>Diesel</run>
            <run fontcolor='#000000' fontname='Times New Roman'> units maintain a higher market floor, </run>
            <run bold='true' fontcolor='#000000' fontname='Times New Roman'>Gas</run>
            <run fontcolor='#000000' fontname='Times New Roman'> and </run>
            <run bold='true' fontcolor='#000000' fontname='Times New Roman'>Hybrid</run>
            <run fontcolor='#000000' fontname='Times New Roman'> models show tighter price clustering, indicating more predictable valuation in the secondary market.</run>
          </formatted-text>
          <zone-style>
            <format attr='border-color' value='#b4b4b4' />
            <format attr='border-style' value='solid' />
            <format attr='border-width' value='1' />
            <_.fcp.DashboardRoundedCorners.true...format attr='corner-radius' value='8' />
            <format attr='background-color' value='#f3faf9' />
          </zone-style>
        </zone>
      </zones>
